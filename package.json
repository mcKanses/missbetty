{
  "name": "missbetty",
  "version": "1.5.1",
  "description": "Local Docker development domains through one Traefik switchboard",
  "main": "bin/betty.js",
  "bin": {
    "betty": "bin/betty.js"
  },
  "files": [
    "bin/betty.js",
    "bin/cli.js",
    "bin/cli/**",
    "bin/commands/**",
    "bin/utils/**",
    "bin/types.js",
    "assets/logo",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('bin',{recursive:true,force:true})\" && tsc",
    "binary": "node scripts/build-binary.mjs",
    "lint": "eslint src/**/*.ts",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules/**\"",
    "lint:fix": "eslint src/**/*.ts --fix",
    "start": "node bin/betty.js",
    "test": "jest --runInBand",
    "test:serial": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "prepack": "npm run build",
    "release:check": "npm run build && npm run lint && npm test && npm pack --dry-run --ignore-scripts",
    "release:guard": "node scripts/assert-main-branch.mjs",
    "release": "npx -y node@24 node_modules/semantic-release/bin/semantic-release.js",
    "release:publish": "npm run release:check && npm publish",
    "release:patch": "npm run release:guard && npm run release:check && npm version patch",
    "release:minor": "npm run release:guard && npm run release:check && npm version minor",
    "release:major": "npm run release:guard && npm run release:check && npm version major",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "jest --findRelatedTests --passWithNoTests"
    ],
    "**/*.md": [
      "markdownlint-cli2"
    ]
  },
  "keywords": [
    "cli",
    "docker",
    "traefik",
    "reverse-proxy",
    "local-dev",
    "dev-tools",
    "localhost",
    "domains",
    "development",
    "proxy",
    "https",
    "mkcert",
    "dev-environment"
  ],
  "author": "Arda Cansiz <arda.cansiz@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/mcKanses/missbetty#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcKanses/missbetty.git"
  },
  "bugs": {
    "url": "https://github.com/mcKanses/missbetty/issues"
  },
  "icon": "assets/logo/favicon.png",
  "dependencies": {
    "commander": "^11.0.0",
    "inquirer": "^8.2.6",
    "missbetty": "^1.5.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/inquirer": "^8.2.12",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "postject": "^1.0.0-alpha.6",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.1"
  }
}
