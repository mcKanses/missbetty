  },
  "devDependencies": {
    "@types/inquirer": "^8.2.12",
    "@types/jest": "^30.0.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.3.0",
    "postject": "^1.0.0-alpha.6",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
